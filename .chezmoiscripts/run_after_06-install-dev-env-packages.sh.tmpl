#!/bin/bash

{{ if not .devenv }}exit 0{{ end }}
set -e

echo ""
echo "[INFO]: Setting up git tools..."

# Check if pip is available
if ! command -v pip &>/dev/null; then
  echo "[ERROR]: pip not found. Please install Python first."
  exit 1
fi

# Install pre-commit if not present
if command -v pre-commit &>/dev/null; then
  echo "  ✓ pre-commit already installed: $(pre-commit --version)"
else
  pip install pre-commit --break-system-packages > /dev/null
  echo "  ✓ pre-commit installed"
fi

# Install git-filter-repo if not present
if command -v git-filter-repo &>/dev/null; then
  echo "  ✓ git-filter-repo already installed"
else
  pip install git-filter-repo --break-system-packages > /dev/null
  echo "  ✓ git-filter-repo installed"
fi
