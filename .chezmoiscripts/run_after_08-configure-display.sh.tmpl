#!/bin/bash
set -euo pipefail
{{- if eq .profile "desktop" }}
echo ""
echo "[INFO] Configuring display/VT settings for desktop profile..."

BOOTLOADER=""
if [ -d /sys/firmware/efi ] && command -v efibootmgr &>/dev/null; then
  EFI_ENTRIES=$(efibootmgr 2>/dev/null || echo "")
  if echo "$EFI_ENTRIES" | grep -qi 'limine'; then
    BOOTLOADER="limine"
  elif echo "$EFI_ENTRIES" | grep -qi 'grub'; then
    BOOTLOADER="grub"
  fi
fi

if [ -z "$BOOTLOADER" ]; then
  if [ -f /boot/limine.conf ] && command -v limine-update &>/dev/null; then
    BOOTLOADER="limine"
  elif [ -f /boot/grub/grub.cfg ] && command -v grub-mkconfig &>/dev/null; then
    BOOTLOADER="grub"
  fi
fi

echo "  Active bootloader: $BOOTLOADER"

# --- Bootloader-aware kernel param helper ---
NEEDS_UPDATE=false

add_kernel_param() {
  local param="$1"

  case "$BOOTLOADER" in
    limine)
      local conf="/etc/default/limine"
      if ! grep -q "$param" "$conf" 2>/dev/null; then
        sudo sed -i "s|KERNEL_CMDLINE\[default\]+=\"\(.*\)\"|KERNEL_CMDLINE[default]+=\"\1 $param\"|" "$conf"
        NEEDS_UPDATE=true
        echo "  ✓ Added '$param' to Limine kernel cmdline"
      else
        echo "  ✓ '$param' already in Limine kernel cmdline"
      fi
      ;;
    grub)
      local conf="/etc/default/grub"
      if ! grep -q "$param" "$conf" 2>/dev/null; then
        sudo sed -i "s|^GRUB_CMDLINE_LINUX=\"\(.*\)\"|GRUB_CMDLINE_LINUX=\"\1 $param\"|" "$conf"
        NEEDS_UPDATE=true
        echo "  ✓ Added '$param' to GRUB kernel cmdline"
      else
        echo "  ✓ '$param' already in GRUB kernel cmdline"
      fi
      ;;
    *)
      echo "⚠ Unknown bootloader — skipping '$param'. Add it manually to your kernel parameters."
      ;;
  esac
}

# Disable HDMI on VT so console uses only the main DP monitor
add_kernel_param "video=HDMI-A-1:d"

if [ "$NEEDS_UPDATE" = true ]; then
  case "$BOOTLOADER" in
    limine)
      sudo limine-update
      echo "  ✓ Limine config regenerated"
      ;;
    grub)
      sudo grub-mkconfig -o /boot/grub/grub.cfg
      echo "  ✓ GRUB config regenerated"
      ;;
  esac
fi
{{- end }}
