# --- Personal repositories ---
# nvim and hypr are configs and live in ~/.config.
# Everything else is a dev checkout under ~/Projects/<host>/<user>/<repo>.
# pull uses --ff-only so local work is never clobbered by an auto-update.

[".config/hypr"]
type = "git-repo"
url = "https://github.com/quantumfate/hypr"
refreshPeriod = "24h"
[".config/hypr".pull]
args = ["--ff-only"]

[".config/nvim"]
type = "git-repo"
url = "https://github.com/quantumfate/nvim"
refreshPeriod = "24h"
[".config/nvim".pull]
args = ["--ff-only"]

["Projects/github/quantumfate/aiagent"]
type = "git-repo"
url = "git@github.com:quantumfate/aiagent.git"
refreshPeriod = "168h"
["Projects/github/quantumfate/aiagent".pull]
args = ["--ff-only"]

