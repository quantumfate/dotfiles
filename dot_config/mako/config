anchor=top-right
background-color=#24273a
border-color=#c6a0f6
border-radius=0
border-size=2
default-timeout=0
font=Hack Nerf Font Mono 16
height=200
icon-location=left
icon-path=/run/current-system/sw/share/icons/hicolor
icons=1
layer=top
margin=0,0,10,0
max-history=8
max-icon-size=64
outer-margin=40
output=DP-1
padding=15,30,15,30
text-color=#cad3f5
width=700
progress-color=over #363a4f
