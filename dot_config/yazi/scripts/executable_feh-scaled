#!/bin/sh
# Open image(s) in feh, sized to 80% of the focused Hyprland monitor.
# Replicates the feh_scaled zsh function (yazi runs sh, which has no zsh fns).
geo=""
if command -v hyprctl >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
    w=$(hyprctl -j monitors 2>/dev/null | jq -r '.[]|select(.focused)|.width'  2>/dev/null)
    h=$(hyprctl -j monitors 2>/dev/null | jq -r '.[]|select(.focused)|.height' 2>/dev/null)
    if [ -n "$w" ] && [ -n "$h" ] && [ "$w" -gt 0 ] 2>/dev/null; then
        geo="--geometry $((w * 80 / 100))x$((h * 80 / 100))"
    fi
fi
exec feh $geo --scale-down "$@"
