#!/bin/sh
# lf previewer with native kitty graphics protocol

file="$1"
w="$2"
h="$3"
x="$4"
y="$5"

# Cache thumbnails keyed on inode + mtime so we don't reconvert every scroll
hash="$(stat --printf '%n\0%i\0%F\0%s\0%W\0%Y' -- "$(readlink -f "$file")" |
  sha256sum | awk '{print $1}')"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/lf"
CACHE="$CACHE_DIR/$hash"
mkdir -p "$CACHE_DIR"

# Preview dispatcher.
#   Inside tmux: kitty's graphics protocol drifts/stacks because tmux + the
#     absolute --place position is unreliable. Render as chafa text blocks
#     instead — plain colored text that lf draws into the pane and clears like
#     any other preview. Bulletproof in tmux, lower resolution.
#   Outside tmux: full-quality native kitty graphics via direct placement.
show() {
  if [ -n "${TMUX:-}" ]; then
    chafa -f symbols --polite on --animate off -s "${w}x${h}" "$1" 2>/dev/null
  else
    # Fixed image id (1111) + clear-before-draw so re-previews replace instead
    # of stacking. The cleaner deletes image id 1111 — keep the two in sync.
    img_id=1111
    "$HOME/.config/lf/cleaner"
    kitten icat \
      --silent \
      --stdin no \
      --transfer-mode file \
      --image-id "$img_id" \
      --place "${w}x${h}@${x}x${y}" \
      "$1" </dev/null >/dev/tty
  fi
}

case "$(file -Lb --mime-type "$file")" in
image/svg+xml)
  [ ! -f "$CACHE.png" ] && rsvg-convert -o "$CACHE.png" "$file" 2>/dev/null
  show "$CACHE.png"
  ;;
image/*)
  show "$file"
  ;;
video/*)
  [ ! -f "$CACHE.jpg" ] &&
    ffmpegthumbnailer -i "$file" -o "$CACHE.jpg" -s 0 -q 5 2>/dev/null
  show "$CACHE.jpg"
  ;;
application/pdf)
  [ ! -f "$CACHE.jpg" ] &&
    pdftoppm -jpeg -f 1 -singlefile "$file" "$CACHE" 2>/dev/null
  show "$CACHE.jpg"
  ;;
application/epub+zip)
  [ ! -f "$CACHE.png" ] &&
    gnome-epub-thumbnailer "$file" "$CACHE.png" 2>/dev/null
  show "$CACHE.png"
  ;;
application/zip) unzip -l "$file" ;;
application/x-tar) tar tvf "$file" ;;
application/gzip) tar tzvf "$file" 2>/dev/null || zcat "$file" ;;
text/* | application/json | application/javascript | application/xml | application/x-shellscript)
  bat --color=always --style=plain --pager=never --terminal-width="$w" "$file"
  ;;
*)
  file -Lb "$file"
  ;;
esac

# Exit 1 tells lf NOT to cache the preview output in memory — critical for
# image previews because the escape codes are positioned absolutely and
# can't be replayed.
exit 1
