#!/bin/sh
# lf previewer with native kitty graphics protocol

file="$1"
w="$2"
h="$3"
x="$4"
y="$5"

# Cache thumbnails keyed on inode + mtime so we don't reconvert every scroll
hash="$(stat --printf '%n\0%i\0%F\0%s\0%W\0%Y' -- "$(readlink -f "$file")" |
  sha256sum | awk '{print $1}')"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/lf"
CACHE="$CACHE_DIR/$hash"
mkdir -p "$CACHE_DIR"

# Preview dispatcher — full-quality native kitty graphics in and out of tmux.
#
# In tmux, --passthrough tmux implies unicode placeholders, whose cells are
# written to /dev/tty (outside lf's control). lf re-runs the previewer on the
# SAME file (resize, returning from an opened app, redraws), and each run lays
# down a fresh block of cells that STACKS on the previous one. Guard against it:
# only (re)draw when the file path OR the pane geometry actually changed. A
# state file records the last draw; the cleaner deletes it on every file change
# (see ~/.config/lf/cleaner), so returning to a file always redraws.
STATE="${XDG_RUNTIME_DIR:-/tmp}/lf-kitty-preview"
show() {
  sig="$1|$w|$h|$x|$y"
  if [ -n "${TMUX:-}" ]; then
    [ "$(cat "$STATE" 2>/dev/null)" = "$sig" ] && return 0   # already on screen
    printf '%s' "$sig" >"$STATE"
    kitten icat \
      --silent \
      --stdin no \
      --transfer-mode memory \
      --passthrough tmux \
      --image-id 1111 \
      --place "${w}x${h}@${x}x${y}" \
      "$1" </dev/null >/dev/tty
  else
    # Outside tmux: direct placement. Fixed image id + clear-before-draw so
    # re-previews replace instead of stacking. Cleaner deletes image id 1111.
    "$HOME/.config/lf/cleaner"
    kitten icat \
      --silent \
      --stdin no \
      --transfer-mode file \
      --image-id 1111 \
      --place "${w}x${h}@${x}x${y}" \
      "$1" </dev/null >/dev/tty
  fi
}

case "$(file -Lb --mime-type "$file")" in
image/svg+xml)
  [ ! -f "$CACHE.png" ] && rsvg-convert -o "$CACHE.png" "$file" 2>/dev/null
  show "$CACHE.png"
  ;;
image/*)
  show "$file"
  ;;
video/*)
  [ ! -f "$CACHE.jpg" ] &&
    ffmpegthumbnailer -i "$file" -o "$CACHE.jpg" -s 0 -q 5 2>/dev/null
  show "$CACHE.jpg"
  ;;
application/pdf)
  [ ! -f "$CACHE.jpg" ] &&
    pdftoppm -jpeg -f 1 -singlefile "$file" "$CACHE" 2>/dev/null
  show "$CACHE.jpg"
  ;;
application/epub+zip)
  [ ! -f "$CACHE.png" ] &&
    gnome-epub-thumbnailer "$file" "$CACHE.png" 2>/dev/null
  show "$CACHE.png"
  ;;
application/zip) unzip -l "$file" ;;
application/x-tar) tar tvf "$file" ;;
application/gzip) tar tzvf "$file" 2>/dev/null || zcat "$file" ;;
text/* | application/json | application/javascript | application/xml | application/x-shellscript)
  bat --color=always --style=plain --pager=never --terminal-width="$w" "$file"
  ;;
*)
  file -Lb "$file"
  ;;
esac

# Exit 1 tells lf NOT to cache the preview output in memory — required for the
# non-tmux kitty path (absolutely-positioned escapes can't be replayed). Harmless
# for the chafa/text paths: lf just re-renders them, which clears cleanly.
exit 1
