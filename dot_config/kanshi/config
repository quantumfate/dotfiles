profile desktop {
  output DP-2 mode 2560x1440@143.86Hz position 0,0 scale 1
  output DP-1 mode 5120x1440@119.99Hz position 2560,0 scale 1
  output HDMI-A-1 mode 800x1280@59.97Hz position 7680,0 scale 1 transform 90
  exec hyprctl dispatch moveworkspacetomonitor "1 DP-1"
  exec hyprctl dispatch moveworkspacetomonitor "2 DP-1"
  exec hyprctl dispatch moveworkspacetomonitor "3 DP-1"
  exec hyprctl dispatch moveworkspacetomonitor "4 DP-1"
  exec hyprctl dispatch moveworkspacetomonitor "5 DP-1"
  exec hyprctl dispatch moveworkspacetomonitor "6 DP-2"
  exec hyprctl dispatch moveworkspacetomonitor "7 DP-2"
  exec hyprctl dispatch moveworkspacetomonitor "8 DP-2"
  exec hyprctl dispatch moveworkspacetomonitor "9 DP-2"
  exec hyprctl dispatch moveworkspacetomonitor "10 DP-2"
  exec xrandr --output DP-1 --primary
}

